{
  "name": "github-profile-analyzer",
  "version": "1.0.0",
  "description": "Production-ready REST API for analyzing GitHub user profiles with MySQL persistence",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit",
    "test:unit": "jest tests/unit --coverage --forceExit",
    "test:integration": "jest tests/integration --coverage --forceExit",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix"
  },
  "keywords": [
    "github",
    "analyzer",
    "api",
    "nodejs",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "axios-retry": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "lru-cache": "^10.2.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "sequelize": "^6.36.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "sequelize-mock": "^0.10.2",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.4"
  }
}
